{
  "name": "reinfer-ai-sdk",
  "version": "0.1.0",
  "description": "Vercel AI SDK proxy with automatic output validation and retry",
  "type": "module",
  "main": "./dist/index.mjs",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "bun --watch run build",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "reinfer": "workspace:*"
  },
  "peerDependencies": {
    "ai": "^6.0.0"
  },
  "devDependencies": {
    "ai": "^6.0.0",
    "tsdown": "^0.22.0"
  }
}
