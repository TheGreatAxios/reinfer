{
  "name": "reinfer-ai-sdk",
  "version": "0.0.1",
  "description": "Vercel AI SDK proxy with automatic output validation and retry",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
