{
  "name": "reinfer",
  "version": "0.0.1",
  "description": "Shared validation engine, schemas, auto-fix, and retry logic for reinfer",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./auto-fix": {
      "types": "./src/auto-fix.ts",
      "import": "./src/auto-fix.ts",
      "default": "./src/auto-fix.ts"
    },
    "./schemas": {
      "types": "./src/schemas/index.ts",
      "import": "./src/schemas/index.ts",
      "default": "./src/schemas/index.ts"
    },
    "./retry": {
      "types": "./src/retry.ts",
      "import": "./src/retry.ts",
      "default": "./src/retry.ts"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./auto-fix": {
        "types": "./dist/auto-fix.d.ts",
        "import": "./dist/auto-fix.js"
      },
      "./schemas": {
        "types": "./dist/schemas/index.d.ts",
        "import": "./dist/schemas/index.js"
      },
      "./retry": {
        "types": "./dist/retry.d.ts",
        "import": "./dist/retry.js"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "bun --watch run build",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "devDependencies": {
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  }
}
